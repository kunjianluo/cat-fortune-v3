{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ingredients.schema.json",
  "title": "Ingredients",
  "type": "object",
  "required": ["ingredients"],
  "properties": {
    "_comment": { "type": "string" },
    "ingredients": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "shop_id", "short_desc", "sprite_key", "order", "is_active"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "shop_id": { "type": "string" },
          "short_desc": { "type": "string" },
          "sprite_key": { "type": "string" },
          "order": { "type": "number" },
          "is_active": { "type": "boolean" }
        }
      }
    }
  }
}


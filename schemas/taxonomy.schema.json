{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "taxonomy.schema.json",
  "title": "Taxonomy",
  "type": "object",
  "required": ["categories"],
  "properties": {
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "order", "children"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "order": { "type": "number" },
          "children": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "name", "order", "issues"],
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "order": { "type": "number" },
                "issues": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}


{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "shops.schema.json",
  "title": "Shops",
  "type": "object",
  "required": ["shops"],
  "properties": {
    "shops": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "short_name", "order"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "short_name": { "type": "string" },
          "order": { "type": "number" },
          "description": { "type": "string" },
          "door_type": { "type": "string" },
          "theme_color": { "type": "string" },
          "bgm_key": { "type": "string" },
          "npc_id": { "type": "string" }
        }
      }
    }
  }
}

